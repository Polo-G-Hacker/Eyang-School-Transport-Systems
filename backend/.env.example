# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://ests:ests_password@localhost:5432/ests

# JWT
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=12h
QR_SECRET=replace-with-another-long-random-string

# Email (SMTP). For local dev, point to MailHog (docker-compose) on localhost:1025.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="ESTS Transport <no-reply@ests.local>"

# Frontend base URL (for email verification links)
APP_BASE_URL=http://localhost:8100

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
